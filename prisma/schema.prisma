generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String                @id @default(cuid())
  email              String                @unique
  emailVerified      DateTime?
  passwordHash       String?
  name               String?
  image              String?
  planType           PlanType              @default(FREE)
  subscriptionStatus SubscriptionStatus    @default(INACTIVE)
  role               UserRole              @default(USER)
  isBanned           Boolean               @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  lastLoginAt        DateTime?
  accounts           Account[]
  views              ArticleView[]
  bookmarks          Bookmark[]
  sessions           Session[]
  subscriptions      Subscription[]
  feedbacks          TranslationFeedback[]

  @@index([email])
  @@index([createdAt])
  @@index([planType])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  access_token      String?
  refresh_token     String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  type              String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  /// Paddle subscription id (Prisma maps to legacy DB column `lemonSqueezyId`)
  paddleSubscriptionId String             @unique @map("lemonSqueezyId")
  orderId              Int
  variantId            Int
  status               SubscriptionStatus @default(INACTIVE)
  planType             PlanType
  price                Int
  currency             String             @default("USD")
  renewsAt             DateTime?
  endsAt               DateTime?
  cancelledAt          DateTime?
  trialStart           DateTime?
  trialEnd             DateTime?
  metadata             Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([paddleSubscriptionId])
}

/// Knowledge Base: structured tutorials, guides, and reference material (Codcompass taxonomy).
/// Distinct from `BlogPost`, which holds practitioner experience-style articles.
model Article {
  id              String               @id @default(dbgenerated("gen_random_uuid()"))
  slug            String               @unique
  originalUrl     String?
  titleEn         String
  contentEn       String
  descriptionEn   String?
  excerptEn       String?
  sourceSite      String?
  sourceAuthor    String?
  crawledAt       DateTime?
  status          ArticleStatus        @default(DRAFT)
  isPublished     Boolean              @default(false)
  isPremium       Boolean              @default(true)
  publishedAt     DateTime?
  viewCount       Int                  @default(0)
  likeCount       Int                  @default(0)
  qualityScore    Int?
  qualityDetails  Json?
  seoTitle        String?
  seoDescription  String?
  canonicalUrl    String?
  publishedBy     String?
  editedAt        DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  difficultyLevel String?
  readingTime     Int?
  expectedOutcome String?
  seriesId        String?
  seriesOrder     Int?
  blueprintUrl    String?
  blueprintName   String?
  accessLevel     String               @default("free")
  isFeatured      Boolean?
  metadata        Json?
  series          ArticleSeries?       @relation(fields: [seriesId], references: [id])
  translations    ArticleTranslation[]
  views           ArticleView[]
  bookmarks       Bookmark[]
  categories      Category[]           @relation("ArticleToCategory")
  tags            Tag[]                @relation("ArticleToTag")

  @@index([slug])
  @@index([status])
  @@index([isPublished])
  @@index([publishedAt])
  @@index([sourceSite])
  @@index([seriesId])
  @@index([difficultyLevel])
  @@index([status], map: "idx_articles_status")
}

model ArticleTranslation {
  id               String    @id @default(cuid())
  articleId        String
  locale           String
  title            String
  content          String
  description      String?
  excerpt          String?
  seoTitle         String?
  seoDescription   String?
  isAutoTranslated Boolean   @default(true)
  isReviewed       Boolean   @default(false)
  reviewedAt       DateTime?
  reviewedBy       String?
  qualityScore     Float?
  feedbackCount    Int       @default(0)
  translatedAt     DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  article          Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, locale])
  @@index([locale])
  @@index([isReviewed])
}

/// Knowledge Base taxonomy only (`cc20-*`, legacy crawled categories). Not used by marketing blog.
model Category {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  nameEn      String
  description String?
  parentId    String?
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  parent      Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryToCategory")
  articles    Article[]  @relation("ArticleToCategory")

  @@index([slug])
  @@index([parentId])
}

/// Blog categories: lightweight grouping for experience posts (separate from KB `Category`).
model BlogCategory {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  nameEn      String
  description String?
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  posts       BlogPost[]

  @@index([slug])
}

/// Blog posts: experience notes, lessons learned, and third-party practitioner perspectives.
/// Not KB reference material—use `Article` for curated knowledge-base content.
model BlogPost {
  id             String       @id @default(cuid())
  slug           String       @unique
  title          String
  contentHtml    String
  excerpt        String?
  /// Original author or contributor name (often someone outside core KB editorial).
  author         String?
  readingMinutes Int          @default(5)
  isPublished    Boolean      @default(false)
  publishedAt    DateTime?
  viewCount      Int          @default(0)
  seoTitle       String?
  seoDescription String?
  tags           String[]     @default([])
  categoryId     String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  isFeatured     Boolean?
  category       BlogCategory @relation(fields: [categoryId], references: [id])

  @@index([slug])
  @@index([isPublished, publishedAt])
  @@index([categoryId])
}

model Tag {
  id         String    @id @default(cuid())
  slug       String    @unique
  name       String
  nameEn     String
  usageCount Int       @default(0)
  createdAt  DateTime  @default(now())
  articles   Article[] @relation("ArticleToTag")

  @@index([slug])
}

model ArticleView {
  id             String   @id @default(cuid())
  articleId      String
  userId         String?
  sessionId      String?
  ipAddress      String?
  readPercentage Int      @default(0)
  readTime       Int      @default(0)
  createdAt      DateTime @default(now())
  article        Article  @relation(fields: [articleId], references: [id])
  user           User?    @relation(fields: [userId], references: [id])

  @@unique([articleId, userId, sessionId])
  @@index([articleId])
  @@index([userId])
}

model Bookmark {
  id        String   @id @default(cuid())
  articleId String
  userId    String
  folder    String?
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId])
}

model TranslationFeedback {
  id        String   @id @default(cuid())
  articleId String
  locale    String
  userId    String?
  score     Int
  comment   String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([articleId, locale])
}

model CrawlerConfig {
  id                       String   @id @default(cuid())
  schedule                 String   @default("0 * * * *")
  enabled                  Boolean  @default(true)
  sources                  Json     @default("[]")
  translateContent         Boolean  @default(true)
  translateTargetLanguages Json     @default("[\"zh\"]")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([enabled])
}

/// Admin「立即运行」派发记录；实际爬虫在 GitHub Actions 等外部执行
model CrawlerJob {
  id             String   @id
  status         String   @default("queued")
  triggerSource  String   @default("admin")
  dispatchTarget String?
  githubRunUrl   String?
  githubRunId    String?
  errorMessage   String?
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model ArticleSeries {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  titleEn       String
  description   String?
  totalParts    Int       @default(1)
  estimatedTime Int?
  order         Int       @default(0)
  isPublished   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  articles      Article[]

  @@index([slug])
  @@index([isPublished])
  @@index([order])
}

enum UserRole {
  USER
  ADMIN
  EDITOR
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
  PAST_DUE
}

enum PlanType {
  FREE
  BUILDER
  PRO
  ENTERPRISE
}

enum ArticleStatus {
  DRAFT
  PROCESSING
  REVIEW
  PUBLISHED
  ARCHIVED
}
