generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                @id @default(cuid())
  email              String                @unique
  emailVerified      DateTime?
  passwordHash       String?
  name               String?
  image              String?
  planType           PlanType              @default(FREE)
  subscriptionStatus SubscriptionStatus    @default(INACTIVE)
  role               UserRole              @default(USER)
  isBanned           Boolean               @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  lastLoginAt        DateTime?
  accounts           Account[]
  views              ArticleView[]
  bookmarks          Bookmark[]
  subscriptions      Subscription[]
  feedbacks          TranslationFeedback[]

  @@index([email])
  @@index([createdAt])
  @@index([planType])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  access_token      String?
  refresh_token     String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Subscription {
  id             String             @id @default(cuid())
  userId         String
  lemonSqueezyId String             @unique
  orderId        Int
  variantId      Int
  status         SubscriptionStatus @default(INACTIVE)
  planType       PlanType
  price          Int
  currency       String             @default("USD")
  renewsAt       DateTime?
  endsAt         DateTime?
  cancelledAt    DateTime?
  trialStart     DateTime?
  trialEnd       DateTime?
  metadata       Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([lemonSqueezyId])
}

model Article {
  id             String               @id @default(cuid())
  slug           String               @unique
  originalUrl    String?
  titleEn        String
  contentEn      String
  descriptionEn  String?
  excerptEn      String?
  sourceSite     String?
  sourceAuthor   String?
  crawledAt      DateTime?
  status         ArticleStatus        @default(DRAFT)
  isPublished    Boolean              @default(false)
  isPremium      Boolean              @default(true)
  accessLevel    String               @default("free")
  publishedAt    DateTime?
  viewCount      Int                  @default(0)
  likeCount      Int                  @default(0)
  qualityScore   Int?
  qualityDetails Json?
  metadata       Json?
  seoTitle       String?
  seoDescription String?
  canonicalUrl   String?
  publishedBy    String?
  editedAt       DateTime?
  
  // Codcompass 2.0 新增字段
  difficultyLevel String?              // L1, L2, L3, L4
  readingTime     Int?                 // 预计阅读时间（分钟）
  expectedOutcome String?              // 预期收益短句
  seriesId        String?              // 所属专题 ID
  seriesOrder     Int?                 // 专题中的顺序
  blueprintUrl    String?              // Production Blueprint 下载链接
  blueprintName   String?              // Blueprint 文件名
  
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  translations   ArticleTranslation[]
  views          ArticleView[]
  bookmarks      Bookmark[]
  categories     Category[]           @relation("ArticleToCategory")
  tags           Tag[]                @relation("ArticleToTag")
  series         ArticleSeries?       @relation(fields: [seriesId], references: [id])

  @@index([slug])
  @@index([status])
  @@index([isPublished])
  @@index([publishedAt])
  @@index([sourceSite])
  @@index([seriesId])
  @@index([difficultyLevel])
}

model ArticleTranslation {
  id               String    @id @default(cuid())
  articleId        String
  locale           String
  title            String
  content          String
  description      String?
  excerpt          String?
  seoTitle         String?
  seoDescription   String?
  isAutoTranslated Boolean   @default(true)
  isReviewed       Boolean   @default(false)
  reviewedAt       DateTime?
  reviewedBy       String?
  qualityScore     Float?
  feedbackCount    Int       @default(0)
  translatedAt     DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  article          Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, locale])
  @@index([locale])
  @@index([isReviewed])
}

model Category {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  nameEn      String
  description String?
  parentId    String?
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  parent      Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryToCategory")
  articles    Article[]  @relation("ArticleToCategory")

  @@index([slug])
  @@index([parentId])
}

model Tag {
  id         String    @id @default(cuid())
  slug       String    @unique
  name       String
  nameEn     String
  usageCount Int       @default(0)
  createdAt  DateTime  @default(now())
  articles   Article[] @relation("ArticleToTag")

  @@index([slug])
}

model ArticleView {
  id             String   @id @default(cuid())
  articleId      String
  userId         String?
  sessionId      String?
  ipAddress      String?
  readPercentage Int      @default(0)
  readTime       Int      @default(0)
  createdAt      DateTime @default(now())
  article        Article  @relation(fields: [articleId], references: [id])
  user           User?    @relation(fields: [userId], references: [id])

  @@unique([articleId, userId, sessionId])
  @@index([articleId])
  @@index([userId])
}

model Bookmark {
  id        String   @id @default(cuid())
  articleId String
  userId    String
  folder    String?
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId])
}

model TranslationFeedback {
  id        String   @id @default(cuid())
  articleId String
  locale    String
  userId    String?
  score     Int
  comment   String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([articleId, locale])
}

model CrawlerConfig {
  id                     String   @id @default(cuid())
  schedule               String   @default("0 * * * *")
  enabled                Boolean  @default(true)
  sources                Json     @default("[]")
  translateContent       Boolean  @default(true)
  translateTargetLanguages Json   @default("[\"zh\"]")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([enabled])
}

// Codcompass 2.0 新增：专题路径模型
model ArticleSeries {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  titleEn     String
  description String?
  totalParts  Int       @default(1)
  estimatedTime Int?    // 总预计学习时间（分钟）
  order       Int       @default(0)
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  articles    Article[]

  @@index([slug])
  @@index([isPublished])
  @@index([order])
}

enum UserRole {
  USER
  ADMIN
  EDITOR
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
  PAST_DUE
}

enum PlanType {
  FREE
  BUILDER
  PRO
  ENTERPRISE
}

enum ArticleStatus {
  DRAFT
  PROCESSING
  REVIEW
  PUBLISHED
  ARCHIVED
}
