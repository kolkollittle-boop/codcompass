{
  "vector_store": {
    "type": "qdrant",
    "url": "http://localhost:6333",
    "collection_name": "codcompass_rag",
    "embedding_model": "BAAI/bge-large-en-v1.5",
    "embedding_dim": 1024,
    "hnsw_config": {
      "m": 32,
      "ef_construction": 400,
      "ef_search": 100
    },
    "batch_size": 100,
    "commit_interval_seconds": 30
  },
  "retrieval": {
    "hybrid": {
      "enabled": true,
      "alpha_default": 0.6,
      "alpha_precise": 0.3,
      "alpha_conceptual": 0.8,
      "rrf_k": 60,
      "top_k": 10,
      "top_k_intermediate": 30
    },
    "reranking": {
      "enabled": true,
      "model": "BAAI/bge-reranker-large",
      "top_k_rerank": 15,
      "url": "http://localhost:8080"
    },
    "filters": {
      "indexed_fields": ["doc_type", "version", "language", "created_at"],
      "hot_months": 6,
      "warm_months": 24
    }
  },
  "chunking": {
    "strategy": "recursive",
    "chunk_size": 1000,
    "chunk_overlap": 200,
    "separators": ["\n\n", "\n", "。", "！", "？", ".", "!", "?", " ", ""],
    "max_tokens_per_chunk": 8191
  },
  "monitoring": {
    "prometheus_url": "http://localhost:9090",
    "metrics": ["recall_at_10", "precision_at_10", "latency_p95", "memory_usage"]
  }
}
