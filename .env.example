# Database
DATABASE_URL="postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"
DIRECT_URL="postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?pgbouncer=true"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# NextAuth / Auth.js v5
NEXTAUTH_URL="http://localhost:3000"
# In production, set your actual site URL (e.g., https://www.codcompass.com)

# IMPORTANT: AUTH_SECRET / NEXTAUTH_SECRET must be a FIXED random value!
# Generate once with: openssl rand -base64 32
# Then use the SAME value everywhere - do NOT change it after deployment
# Changing it will invalidate all user sessions
AUTH_SECRET="your-fixed-random-key-here"
# Or use legacy name: NEXTAUTH_SECRET="same-value"

# Google OAuth
# You can use either naming convention:
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"
# Or legacy: GOOGLE_CLIENT_ID="..." / GOOGLE_CLIENT_SECRET="..."

# Paddle Billing (checkout + webhooks)
# https://developer.paddle.com/
# Use production with live API keys (otherwise customer email fetch hits sandbox and fails).
PADDLE_ENV="sandbox"
PADDLE_API_KEY="YOUR_PADDLE_API_KEY"
PADDLE_WEBHOOK_SECRET="YOUR_PADDLE_WEBHOOK_SECRET"
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN="YOUR_PADDLE_CLIENT_TOKEN"
PADDLE_BUILDER_MONTHLY_PRICE_ID=""
PADDLE_BUILDER_YEARLY_PRICE_ID=""
PADDLE_PRO_MONTHLY_PRICE_ID=""
PADDLE_PRO_YEARLY_PRICE_ID=""

# API Keys (comma-separated for multiple keys)
API_KEYS="your-secret-api-key-here"

# ─── Crawler Proxy Pool (代理池轮换) ─────────────────────────────────────
# 配置多个代理出口，爬虫会自动轮换使用，请求失败时切换到下一个代理
# 格式：逗号分隔的代理 URL 列表
# 示例（Clash/Surge 本地代理）：
# PROXY_POOL_URLS="http://127.0.0.1:7890,http://127.0.0.1:7891,http://127.0.0.1:7892"
#
# 如果未设置 PROXY_POOL_URLS，则回退使用单个 HTTP_PROXY / HTTPS_PROXY
HTTP_PROXY="http://127.0.0.1:7890"
HTTPS_PROXY="http://127.0.0.1:7890"
PROXY_POOL_URLS=""

# ─── Crawler Settings (爬虫设置) ─────────────────────────────────────────
CRAWLER_PUSH="true"
CRAWLER_SCORE_THRESHOLD="80"
INGEST_SECRET="your-ingest-secret-here"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Crawler Continuous Running (持续运行设置) ──────────────────────────
# 爬虫会持续运行，直到达到以下推送目标数量
# TARGET_KB_PUSHED: 推送到 KB 的文章数量目标（0 表示不限制）
# TARGET_BLOG_PUSHED: 推送到 Blog 的文章数量目标（0 表示不限制）
# MAX_CRAWL_ROUNDS: 最大抓取轮次（防止无限运行，默认 5）
TARGET_KB_PUSHED="0"
TARGET_BLOG_PUSHED="0"
MAX_CRAWL_ROUNDS="5"

# ─── LLM / AI (OpenRouter) ──────────────────────────────────────────────
OPENROUTER_API_KEY="your-openrouter-api-key"
