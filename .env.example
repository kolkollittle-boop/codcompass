# Database
DATABASE_URL="postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"
DIRECT_URL="postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?pgbouncer=true"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# NextAuth / Auth.js v5 (aliases: AUTH_* ↔ NEXTAUTH_*)
NEXTAUTH_URL="http://localhost:3000"
# In production, set your actual site URL
# NEXTAUTH_URL="https://yourdomain.com"

# Use either AUTH_SECRET (v5 preferred) or NEXTAUTH_SECRET
AUTH_SECRET="generate-with: openssl rand -base64 32"
# NEXTAUTH_SECRET="same-as-AUTH_SECRET-if-you-prefer-legacy-name"

# Trust host - required for production self-hosted deployments
# AUTH_TRUST_HOST="true"

# Google OAuth
# NextAuth v5 supports both naming conventions:
# Option 1 (v5 preferred): AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET
# Option 2 (legacy): GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Paddle Billing (checkout + webhooks)
# https://developer.paddle.com/
# Use production with live API keys (otherwise customer email fetch hits sandbox and fails).
PADDLE_ENV="sandbox"
PADDLE_API_KEY="YOUR_PADDLE_API_KEY"
PADDLE_WEBHOOK_SECRET="YOUR_PADDLE_WEBHOOK_SECRET"
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN="YOUR_PADDLE_CLIENT_TOKEN"
PADDLE_BUILDER_MONTHLY_PRICE_ID=""
PADDLE_BUILDER_YEARLY_PRICE_ID=""
PADDLE_PRO_MONTHLY_PRICE_ID=""
PADDLE_PRO_YEARLY_PRICE_ID=""

# API Keys (comma-separated for multiple keys)
API_KEYS="your-secret-api-key-here"
